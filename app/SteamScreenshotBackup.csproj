<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <AssemblyName>SteamScreenshotBackup</AssemblyName>
    <RootNamespace>SteamScreenshotBackup</RootNamespace>
    <Version>3.11.0</Version>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <Product>Steam Screenshot Backup</Product>
    <Description>Automatically backs up Steam screenshots into per-game folders with readable names.</Description>
  </PropertyGroup>
</Project>
